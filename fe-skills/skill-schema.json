{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Definition",
  "type": "object",
  "required": ["id", "name", "version", "description", "level", "platform", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the skill"
    },
    "name": {
      "type": "string",
      "description": "Display name of the skill"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["macos", "windows", "linux"]
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "title", "action"],
        "properties": {
          "order": {"type": "integer"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "action": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["script", "manual", "verification"]
              },
              "command": {"type": "string"},
              "expected_output": {"type": "string"},
              "documentation": {"type": "string"}
            }
          }
        }
      }
    },
    "estimated_time": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
