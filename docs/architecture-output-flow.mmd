flowchart TB
    subgraph User["User Action"]
        U1["Run: orchestrate.py init"]
    end
    
    subgraph Environment["Environment Setup"]
        E1["Set TASK_CAPTURE_OUTPUT=true"]
        E2["Set TASK_OUTPUT_FILE=.task-output.md"]
        E3["Set system prompt<br/>(via .kimi/KIMI.md)"]
    end
    
    subgraph Execution["AI Agent Execution"]
        A1["AI Agent reads task"]
        A2["AI Agent implements"]
        A3["Check: TASK_CAPTURE_OUTPUT?"]
        A4["Write to .task-output.md"]
        A5["Continue normal output<br/>to Terminal"]
    end
    
    subgraph Capture["Output Capture"]
        C1["Run: orchestrate.py finish"]
        C2["Read .task-output.md"]
        C3["Append to tracing file"]
        C4["Clean up"]
    end
    
    U1 --> E1
    E1 --> E2
    E2 --> E3
    E3 --> A1
    A1 --> A2
    A2 --> A3
    A3 -->|Yes| A4
    A3 -->|No| A5
    A4 --> A5
    A5 --> C1
    C1 --> C2
    C2 --> C3
    C3 --> C4
    
    style A4 fill:#fff3e0,stroke:#ef6c00
    style A5 fill:#e8f5e9,stroke:#2e7d32
    style C2 fill:#fff3e0,stroke:#ef6c00
